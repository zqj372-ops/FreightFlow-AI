generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ShipmentStatus {
  BOOKING_SENT         @map("已发送订舱")
  WAITING_RELEASE      @map("等待放舱")
  RELEASE_FOLLOWED_UP  @map("已催放舱")
  RELEASED             @map("已放舱")
  PENDING_DOCUMENTS    @map("待补料")
  DOCUMENTS_SENT       @map("已发送补料")
  DOCUMENTS_CONFIRMING @map("等待补料确认")
  DOCUMENTS_CONFIRMED  @map("补料已确认")
  PENDING_CUSTOMS      @map("待报关")
  CUSTOMS_DECLARED     @map("已报关")
  PENDING_PICKUP       @map("待提柜")
  PICKED_UP            @map("已提柜")
  LOADED               @map("已装柜")
  RETURNED             @map("已还柜")
  SAILED               @map("已开船")
  ARRIVED              @map("已到港")
  SIGNED               @map("已签收")
  COMPLETED            @map("已完成")
  EXCEPTION_PROCESSING @map("异常处理中")
}

enum AlertLevel {
  RED    @map("red")
  YELLOW @map("yellow")
  GREEN  @map("green")
}

enum DocumentProgressStatus {
  PENDING     @map("待处理")
  DRAFT_READY @map("草稿完成")
  SENT        @map("已发送")
}

enum MailStatus {
  NOT_SENT     @map("未发送")
  SENT         @map("已发送")
  FOLLOWING_UP @map("跟进中")
}

enum SoStatus {
  PENDING_RECOGNITION @map("待识别")
  RECOGNIZED          @map("已识别")
}

enum ShipmentDocumentStatus {
  PENDING_GENERATION @map("待生成")
  PROCESSING         @map("处理中")
  SENT               @map("已发送")
  CONFIRMED          @map("已确认")
}

enum ContactRole {
  BOOKING_AGENT @map("booking_agent")
  OPS           @map("ops")
  SALES         @map("sales")
  CUSTOMS       @map("customs")
}

enum ShipmentActionType {
  BOOKING_EMAIL    @map("订舱邮件")
  FOLLOW_UP        @map("催单提醒")
  DOCUMENTS        @map("补料文件")
  SO_RECOGNITION   @map("SO 识别")
  CUSTOMS_PROGRESS @map("AMS/ACI/ISF")
  EXCEPTION_MARK   @map("异常标记")
}

enum ActionSource {
  UI
  AI     @map("AI")
  SYSTEM @map("SYSTEM")

  @@map("action_source")
}

enum AiRequestStatus {
  IDLE    @map("idle")
  LOADING @map("loading")
  SUCCESS @map("success")
  ERROR   @map("error")
}

enum EmailRecipientType {
  TO @map("to")
  CC @map("cc")
}

enum BookingEmailDraftStatus {
  DRAFT
  APPROVED
  SENT
  FAILED
}

enum SoDocumentSource {
  UPLOAD
  EMAIL_ATTACHMENT
}

enum SoOcrStatus {
  PENDING
  OCR_PROCESSING
  OCR_DONE
  EXTRACTING
  EXTRACTED
  NEED_REVIEW
  FAILED
}

enum EmailSyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Shipment {
  id                  String                    @id @db.VarChar(64)
  batchNo             String                    @unique @db.VarChar(64)
  soNo                String                    @db.VarChar(64)
  containerNo         String                    @db.VarChar(64)
  bookingAgent        String                    @db.VarChar(128)
  carrier             String                    @db.VarChar(128)
  originPort          String                    @db.VarChar(128)
  transitPort         String                    @default("") @db.VarChar(128)
  destinationPort     String                    @db.VarChar(128)
  containerType       String                    @db.VarChar(32)
  vesselVoyage        String                    @db.VarChar(128)
  etd                 DateTime
  eta                 DateTime
  cutoffTime          DateTime
  pickupLocation      String                    @db.VarChar(128)
  returnLocation      String                    @db.VarChar(128)
  status              ShipmentStatus
  operator            String                    @db.VarChar(128)
  followUpCount       Int                       @default(0)
  lastEmailTime       DateTime?
  hoursWaitingRelease Int                       @default(0)
  hoursToCutoff       Int
  aiSummary           String                    @db.Text
  nextAction          String                    @db.Text
  alertLevel          AlertLevel?
  mailStatus          MailStatus
  soStatus            SoStatus
  documentStatus      ShipmentDocumentStatus
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  documentProgress    ShipmentDocumentProgress?
  exceptions          ShipmentException[]
  reminderFlags       ShipmentReminderFlag[]
  actionLogs          ShipmentActionLog[]
  emailLogs           ShipmentEmailLog[]
  bookingEmailDrafts  BookingEmailDraft[]
  soDocuments         SoDocument[]

  @@index([status])
  @@index([operator])
  @@index([carrier])
  @@index([destinationPort])
  @@map("shipments")
}

model BookingEmailDraft {
  id          String                  @id @default(cuid())
  shipmentId  String                  @db.VarChar(64)
  subject     String                  @db.VarChar(255)
  body        String                  @db.Text
  to          Json
  cc          Json?
  status      BookingEmailDraftStatus @default(DRAFT)
  aiRequestId String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  shipment    Shipment                @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("booking_email_drafts")
}

model SoDocument {
  id              String             @id @default(cuid())
  shipmentId      String             @db.VarChar(64)
  fileName        String             @db.VarChar(255)
  mimeType        String             @db.VarChar(128)
  storagePath     String             @db.Text
  source          SoDocumentSource
  ocrStatus       SoOcrStatus        @default(PENDING)
  rawText         String?            @db.Text
  extractedJson   Json?
  confidence      Float?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  shipment        Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  extractedFields SoExtractedField[]

  @@index([shipmentId])
  @@index([ocrStatus])
  @@map("so_documents")
}

model SoExtractedField {
  id           String     @id @default(cuid())
  soDocumentId String
  fieldKey     String     @db.VarChar(128)
  fieldValue   String?    @db.Text
  confidence   Float?
  sourceText   String?    @db.Text
  createdAt    DateTime   @default(now())
  soDocument   SoDocument @relation(fields: [soDocumentId], references: [id], onDelete: Cascade)

  @@index([soDocumentId])
  @@index([fieldKey])
  @@map("so_extracted_fields")
}

model EmailSyncLog {
  id              String          @id @default(cuid())
  mailbox         String          @db.VarChar(255)
  status          EmailSyncStatus
  matchedCount    Int             @default(0)
  attachmentCount Int             @default(0)
  errorMessage    String?         @db.Text
  startedAt       DateTime        @default(now())
  completedAt     DateTime?

  @@index([startedAt])
  @@map("email_sync_logs")
}

model ShipmentDocumentProgress {
  shipmentId String                 @id @db.VarChar(64)
  ams        DocumentProgressStatus
  aci        DocumentProgressStatus
  isf        DocumentProgressStatus
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  shipment   Shipment               @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_document_progress")
}

model ShipmentException {
  id         String   @id @default(cuid())
  shipmentId String   @db.VarChar(64)
  message    String   @db.Text
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, sortOrder])
  @@map("shipment_exceptions")
}

model ShipmentReminderFlag {
  id         String   @id @default(cuid())
  shipmentId String   @db.VarChar(64)
  message    String   @db.Text
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, sortOrder])
  @@map("shipment_reminder_flags")
}

model Contact {
  id        String      @id @default(cuid())
  email     String      @unique @db.VarChar(255)
  label     String      @db.VarChar(128)
  role      ContactRole
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([role])
  @@map("contacts")
}

model ShipmentActionLog {
  id             String             @id @default(cuid())
  shipmentId     String             @db.VarChar(64)
  actionType     ShipmentActionType
  source         ActionSource       @default(UI)
  actorName      String?            @db.VarChar(128)
  actorEmail     String?            @db.VarChar(255)
  summary        String             @db.Text
  beforeSnapshot Json?
  afterSnapshot  Json?
  createdAt      DateTime           @default(now())
  shipment       Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@index([actionType])
  @@map("shipment_action_logs")
}

model ShipmentEmailLog {
  id             String                   @id @default(cuid())
  shipmentId     String                   @db.VarChar(64)
  subject        String                   @db.VarChar(255)
  body           String                   @db.Text
  attachmentName String?                  @db.VarChar(255)
  sentAt         DateTime?
  createdAt      DateTime                 @default(now())
  shipment       Shipment                 @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  recipients     ShipmentEmailRecipient[]

  @@index([shipmentId, createdAt])
  @@map("shipment_email_logs")
}

model ShipmentEmailRecipient {
  id            String             @id @default(cuid())
  emailLogId    String
  email         String             @db.VarChar(255)
  recipientType EmailRecipientType
  createdAt     DateTime           @default(now())
  emailLog      ShipmentEmailLog   @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@index([emailLogId, recipientType])
  @@map("shipment_email_recipients")
}

model AiRequest {
  id             String          @id @default(cuid())
  shipmentId     String?         @db.VarChar(64)
  prompt         String          @db.Text
  reply          String?         @db.Text
  requestStatus  AiRequestStatus
  requestContext Json?
  provider       String?         @db.VarChar(64)
  endpoint       String?         @db.VarChar(255)
  errorMessage   String?         @db.Text
  responseTimeMs Int?
  createdAt      DateTime        @default(now())
  completedAt    DateTime?

  @@index([shipmentId, createdAt])
  @@index([requestStatus])
  @@map("ai_requests")
}
