DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/freightflow_ai?schema=public"
OPENCLAW_API_URL=http://127.0.0.1:8080/api/chat
OPENCLAW_API_KEY=
OPENCLAW_MODEL=
OPENCLAW_TIMEOUT_MS=30000

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FreightFlow AI
SMTP_REPLY_TO=

IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true

# Track B / IMAP pull-in (POST /api/email-sync/run)
# If IMAP_HOST + SMTP_USERNAME + SMTP_PASSWORD are all set, runSync() connects
# to the real IMAP server via imapflow.  Otherwise it falls back to the
# in-process MockEmailPullProvider (3 fixture messages in INBOX).
#   - fullSync: { true } forces a full rescan (default increment mode uses
#     the latest receivedAt as the watermark).
#   - mailbox: defaults to "INBOX".
#   - limit:   max number of UIDs per run (default 50).
# Real IMAP transport failures bubble up to the route as 5xx and are NEVER
# silently downgraded to mock — the report's errors[] array captures the
# per-stage failure and the run stops cleanly.
