DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/freightflow_ai?schema=public"
OPENCLAW_API_URL=http://127.0.0.1:8080/api/chat
OPENCLAW_API_KEY=
OPENCLAW_MODEL=
OPENCLAW_TIMEOUT_MS=30000

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FreightFlow AI
SMTP_REPLY_TO=

IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true

# ---------------------------------------------------------------------------
# IMAP / pull-sync notes
# ---------------------------------------------------------------------------
# /api/email-sync/run picks a pull provider at runtime:
#   - if .freightflow/email-config.json has enabled=true with imapHost/username/
#     password, it uses the real IMAP server.
#   - else if IMAP_HOST + SMTP_USERNAME + SMTP_PASSWORD are all set in env,
#     it uses the real IMAP server.
#   - else it falls back to the in-process MockEmailPullProvider (3 fixture
#     messages) so dev work and tests never require a live mailbox.
#
# A real IMAP transport failure is surfaced as a 5xx — we do NOT silently
# fall back to mock.  Configure the file or env above before pointing
# runSync at a real mailbox.

